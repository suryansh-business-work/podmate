{
  "expo": {
    "name": "PartyWings",
    "slug": "partywings",
    "scheme": "partywings",
    "version": "1.0.0",
    "orientation": "portrait",
    "extra": {
      "apiUrl": "http://192.168.68.61:4039/graphql",
      "googleWebClientId": "508129946567-k7taq7410704i9jj0ntkco11clr5743u.apps.googleusercontent.com",
      "eas": {
        "projectId": "f12c936a-a509-4fdd-89ae-d83ed1959fd9"
      }
    },
    "icon": "./assets/icon-and-splash/logo-1024x1024.png",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android", "web"],
    "splash": {
      "image": "./assets/icon-and-splash/logo-1284x2778.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.partywings.app",
      "icon": "./assets/icon-and-splash/logo-1024x1024.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-and-splash/logo-1024x1024.png",
        "backgroundColor": "#111827"
      },
      "package": "com.partywings.app",
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "plugins": ["expo-video", "@react-native-google-signin/google-signin"],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon-and-splash/logo-1024x1024.png"
    }
  }
}
