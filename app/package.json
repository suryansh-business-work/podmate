{
  "name": "partywings-app",
  "version": "1.0.0",
  "private": true,
  "main": "App.tsx",
  "scripts": {
    "start": "expo start --port 4038",
    "android": "expo start --android --port 4038",
    "ios": "expo start --ios --port 4038",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "build": "npx expo export --platform web",
    "build:apk": "eas build -p android --profile preview",
    "build:apk:dev": "eas build -p android --profile development",
    "build:ios": "eas build -p ios --profile preview",
    "build:ios:dev": "eas build -p ios --profile development",
    "build:prod:android": "eas build -p android --profile production",
    "build:prod:ios": "eas build -p ios --profile production"
  },
  "dependencies": {
    "@apollo/client": "^3.12.0",
    "@expo/metro-runtime": "~6.1.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.0",
    "@fortawesome/free-brands-svg-icons": "^6.7.0",
    "@fortawesome/free-regular-svg-icons": "^6.7.0",
    "@fortawesome/free-solid-svg-icons": "^6.7.0",
    "@fortawesome/react-native-fontawesome": "^0.3.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.3.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-contacts": "~15.0.11",
    "expo-font": "~14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "^19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video": "^3.0.16",
    "formik": "^2.4.6",
    "graphql": "^16.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-paper": "^5.13.0",
    "react-native-reanimated": "^4.1.6",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "yup": "^1.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.5.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
