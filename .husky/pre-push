#!/usr/bin/env sh

# Pre-push hook: Run type-check + lint before allowing push
echo "🔍 Running pre-push checks..."

pnpm type-check
if [ $? -ne 0 ]; then
  echo "❌ Type check failed. Push aborted."
  exit 1
fi

pnpm lint
if [ $? -ne 0 ]; then
  echo "❌ Lint check failed. Push aborted."
  exit 1
fi

echo "✅ Pre-push checks passed."
