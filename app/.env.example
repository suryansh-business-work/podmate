# App API Configuration
# Replace with your machine's local IP (run: ipconfig -> Wi-Fi IPv4 Address)
EXPO_PUBLIC_API_URL=http://192.168.68.61:4039/graphql
EXPO_PUBLIC_WS_URL=ws://192.168.68.61:4039/ws

# Google Sign-In (Web OAuth Client ID from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
