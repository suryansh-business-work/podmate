{
  "name": "partywings",
  "version": "1.0.0",
  "private": true,
  "description": "PartyWings — Trust-based communities platform",
  "scripts": {
    "dev:server": "pnpm --filter partywings-server dev",
    "dev:website": "pnpm --filter partywings-website dev",
    "dev:admin": "pnpm --filter partywings-admin dev",
    "dev:app": "pnpm --filter partywings-app start",
    "dev:all": "pnpm dev:server & pnpm dev:admin & pnpm dev:website",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "test": "pnpm -r test",
    "type-check": "pnpm -r type-check",
    "build:apk": "pnpm --filter partywings-app build:apk",
    "build:ios": "pnpm --filter partywings-app build:ios",
    "build:apk:dev": "pnpm --filter partywings-app build:apk:dev",
    "build:ios:dev": "pnpm --filter partywings-app build:ios:dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
