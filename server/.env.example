# Server Configuration
PORT=4039
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/podify

# JWT
JWT_SECRET=your-jwt-secret-here

# SMTP Email Configuration
