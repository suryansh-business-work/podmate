SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@partywings.com

# ImageKit
IMAGEKIT_PUBLIC_KEY=public_kgj5PULxw6pfjeO2IGwEVundBIQ=
IMAGEKIT_PRIVATE_KEY=private_n4IdSlg7DbXXn88rRAVqZhCgGVw=
IMAGEKIT_URL_ENDPOINTS=https://ik.imagekit.io/esdata1

# Dev Admin Email
DEV_EMAIL=suryansh@exyconn.com

# Google OAuth (Web Client ID for verifying Google Sign-In ID tokens)
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Google Calendar Integration (optional — can also be set via Admin Panel > Configuration)
GOOGLE_CALENDAR_CLIENT_ID=your-oauth2-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your-oauth2-client-secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your-oauth2-refresh-token
